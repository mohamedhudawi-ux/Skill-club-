{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for all roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "staff", "safa", "admin"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "admissionNumber": { "type": "string", "description": "Only for students" },
        "totalPoints": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Detailed student information.",
      "type": "object",
      "properties": {
        "admissionNumber": { "type": "string" },
        "name": { "type": "string" },
        "dob": { "type": "string" },
        "fatherName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "class": { "type": "string" },
        "totalPoints": { "type": "number" },
        "categoryPoints": {
          "type": "object",
          "description": "Map of category names to points"
        }
      },
      "required": ["admissionNumber", "name"]
    },
    "Club": {
      "title": "Club",
      "description": "A student club.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "totalPoints": { "type": "number" }
      },
      "required": ["name"]
    },
    "ClubPointEntry": {
      "title": "Club Point Entry",
      "description": "Points awarded to a club.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "points": { "type": "number" },
        "description": { "type": "string" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "points", "description", "addedBy", "timestamp"]
    },
    "MonthlyReport": {
      "title": "Monthly Report",
      "description": "Monthly activity report for Safa Union.",
      "type": "object",
      "properties": {
        "month": { "type": "string", "description": "YYYY-MM format" },
        "reportText": { "type": "string" },
        "submittedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "reportText", "submittedBy", "timestamp"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction for Safa Union.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "description", "date", "addedBy", "timestamp"]
    },
    "ClubMember": {
      "title": "Club Member",
      "description": "A member of a club.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["clubId", "name", "position"]
    },
    "Board": {
      "title": "Board",
      "description": "A Safa board.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "BoardMember": {
      "title": "Board Member",
      "description": "A member of a board.",
      "type": "object",
      "properties": {
        "boardId": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["boardId", "name", "position"]
    },
    "WorkSubmission": {
      "title": "Work Submission",
      "description": "Student work submitted for points.",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string" },
        "studentName": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "link": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "pointsAwarded": { "type": "number" },
        "reviewedBy": { "type": "string" },
        "reviewComment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentUid", "admissionNumber", "category", "title", "status"]
    },
    "OfficeBearer": {
      "title": "Office Bearer",
      "description": "A Skill Club office bearer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "position": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["name", "position"]
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "Editable site content.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "SkillClubEntry": {
      "title": "SkillClub Entry",
      "description": "A record of student performance in a program.",
      "type": "object",
      "properties": {
        "studentAdmissionNumber": { "type": "string" },
        "category": { "type": "string" },
        "points": { "type": "number" },
        "description": { "type": "string" },
        "addedBy": { "type": "string", "description": "UID of staff/safa/admin" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentAdmissionNumber", "category", "points"]
    },
    "Program": {
      "title": "Program",
      "description": "A calendar event or program.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An image uploaded to the gallery.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["url"]
    },
    "Query": {
      "title": "Student Query",
      "description": "Queries sent by students to admins.",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string" },
        "studentName": { "type": "string" },
        "message": { "type": "string" },
        "voiceUrl": { "type": "string" },
        "reply": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentUid", "timestamp", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications for users.",
      "type": "object",
      "properties": {
        "recipientUid": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["recipientUid", "title", "message", "timestamp"]
    },
    "CCEMark": {
      "title": "CCE Mark",
      "description": "Continuous and Comprehensive Evaluation marks for students.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "term": { "type": "string", "enum": ["CCE 1", "CCE 2", "CCE 3", "CCE 4"] },
        "mark": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "class", "subject", "term", "mark", "uploadedBy", "timestamp"]
    },
    "Campus": {
      "title": "Campus",
      "description": "Educational campus details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "skillClubName": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    }
  },
  "firestore": {
    "/campuses/{campusId}": {
      "schema": "Campus",
      "description": "Campus information"
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{admissionNumber}": {
      "schema": "Student",
      "description": "Student details"
    },
    "/cceMarks/{markId}": {
      "schema": "CCEMark",
      "description": "CCE Marks records"
    },
    "/skillClubEntries/{entryId}": {
      "schema": "SkillClubEntry",
      "description": "SkillClub performance records"
    },
    "/programs/{programId}": {
      "schema": "Program",
      "description": "Calendar programs"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Gallery images"
    },
    "/clubs/{clubId}": {
      "schema": "Club",
      "description": "Student clubs"
    },
    "/clubMembers/{memberId}": {
      "schema": "ClubMember",
      "description": "Club members"
    },
    "/boards/{boardId}": {
      "schema": "Board",
      "description": "Safa boards"
    },
    "/boardMembers/{memberId}": {
      "schema": "BoardMember",
      "description": "Board members"
    },
    "/workSubmissions/{submissionId}": {
      "schema": "WorkSubmission",
      "description": "Student work submissions"
    },
    "/officeBearers/{bearerId}": {
      "schema": "OfficeBearer",
      "description": "Skill Club office bearers"
    },
    "/siteContent/{contentId}": {
      "schema": "SiteContent",
      "description": "Site content settings"
    },
    "/queries/{queryId}": {
      "schema": "Query",
      "description": "Student queries"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/clubPointEntries/{entryId}": {
      "schema": "ClubPointEntry",
      "description": "Club point records"
    },
    "/monthlyReports/{reportId}": {
      "schema": "MonthlyReport",
      "description": "Monthly activity reports"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    }
  }
}
