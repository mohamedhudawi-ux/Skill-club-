rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // User: uid, email, role (student, staff, safa, admin, academic), admissionNumber?, totalPoints?
    // Student: admissionNumber, name, dob, fatherName, address, phone, email, photoURL, class, totalPoints, categoryPoints
    // SkillClubEntry: studentAdmissionNumber, category, points, description, addedBy, timestamp
    // Program: title, date, description, addedBy, timestamp
    // GalleryItem: url, caption, uploadedBy, timestamp
    // Club: name, description, logoUrl
    // Board: name, description
    // WorkSubmission: studentUid, studentName, admissionNumber, title, description, fileUrl, status, pointsAwarded, reviewedBy, timestamp
    // GraceMarkApplication: studentUid, studentName, admissionNumber, category, reason, status, timestamp
    // Query: studentUid, studentName, message, status, timestamp, reply?
    // Transaction: type, amount, description, date, category, addedBy, timestamp
    // Notification: recipientUid, title, message, timestamp, read
    // SiteContent: key, value
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "mdthaha213@gmail.com" ||
        hasRole('admin')
      );
    }

    function isStaff() {
      return isAdmin() || hasRole('staff') || 
             (isAuthenticated() && request.auth.token.email in [
               'sharfuddin@skill.edu', 'sharafuddin@skill.edu', 'sharafuddinhudawi@skill.edu', 
               'anasp@skill.edu', 'zakirhudawi@skill.edu', 'ali@skill.edu', 'masoom@skill.edu', 
               'zakir@skill.edu', 'nayaz@skill.edu', 'saifullah@skill.edu', 'saifullahk@skill.edu', 
               'irfan@skill.edu', 'shuaib@skill.edu', 'latheef@skill.edu', 'salman@skill.edu', 
               'shefil@skill.edu', 'safwan@skill.edu', 'shibli@skill.edu', 'thaha@skill.edu', 'jawad@skill.edu'
             ]);
    }

    function isSafa() {
      return isStaff() || hasRole('safa');
    }

    function isAcademic() {
      return isStaff() || hasRole('academic');
    }

    function isStudent() {
      return hasRole('student') || isSafa() || isAcademic();
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isStudentOwner(admissionNumber) {
      return isAuthenticated() && getUserData().admissionNumber == admissionNumber;
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.role in ['admin', 'staff', 'safa', 'student', 'academic'];
    }

    // Rules
    
    // Users Collection
    match /users/{uid} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        isAdmin() || 
        isStaff() || 
        isOwner(uid) || 
        ((isSafa() || isAcademic()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'badges', 'totalPoints']))
      );
      allow delete: if isAdmin() || isStaff();
    }

    // Students Collection
    match /students/{admissionNumber} {
      allow read: if true;
      allow create: if isStaff() || isAcademic() || isAdmin();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        isStaff() ||
        isAcademic() ||
        isSafa() ||
        (isStudentOwner(admissionNumber) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoURL', 'name', 'class', 'fatherName', 'dob', 'address', 'phone', 'bio', 'socialLinks']))
      );
      allow delete: if isAdmin() || isStaff();
    }

    // Skill Club Entries
    match /skillClubEntries/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAcademic() || isAdmin() || isSafa();
    }

    // Queries
    match /queries/{queryId} {
      allow read: if isAdmin() || isStaff() || isSafa() || isAcademic() || (isAuthenticated() && resource.data.studentUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.studentUid == request.auth.uid;
      allow update: if isAdmin() || isStaff() || isSafa() || isAcademic() || (isAuthenticated() && resource.data.studentUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['message', 'timestamp', 'reply', 'status']));
      allow delete: if isAdmin() || isStaff() || (isAuthenticated() && resource.data.studentUid == request.auth.uid);
    }

    // Work Submissions
    match /workSubmissions/{submissionId} {
      allow read: if isAdmin() || isStaff() || isSafa() || isAcademic() || (isAuthenticated() && (resource.data.studentUid == request.auth.uid || (getUserData().role == 'student' && getUserData().admissionNumber == resource.data.admissionNumber))) || resource.data.status == 'approved';
      allow create: if isAuthenticated() && request.resource.data.studentUid == request.auth.uid;
      allow update: if isAdmin() || isStaff() || isSafa() || isAcademic() || (isAuthenticated() && resource.data.studentUid == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin() || isStaff() || (isAuthenticated() && resource.data.studentUid == request.auth.uid && resource.data.status == 'pending');
    }

    // Grace Mark Applications
    match /graceMarkApplications/{applicationId} {
      allow read: if isAdmin() || isStaff() || isSafa() || isAcademic() || (isAuthenticated() && (resource.data.studentUid == request.auth.uid || (getUserData().role == 'student' && getUserData().admissionNumber == resource.data.admissionNumber)));
      allow create: if isAuthenticated() && request.resource.data.studentUid == request.auth.uid;
      allow update: if isAdmin() || isStaff() || isSafa() || isAcademic() || (isAuthenticated() && resource.data.studentUid == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin() || isStaff() || (isAuthenticated() && resource.data.studentUid == request.auth.uid && resource.data.status == 'pending');
    }

    // Clubs, Boards, Office Bearers, Members, Programs, Gallery
    match /clubs/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /boards/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /officeBearers/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /members/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /clubMembers/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /boardMembers/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /programs/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /gallery/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /calendar/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }
    match /resources/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }

    // Transactions
    match /treasury/{transactionId} {
      allow read: if isSafa() || isAdmin();
      allow create, update, delete: if isSafa() || isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.recipientUid == request.auth.uid);
      allow create: if isStaff() || isSafa() || isAdmin() || isAcademic() || isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipientUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.recipientUid == request.auth.uid);
    }
    
    // Login Notifications
    match /loginNotifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Site Content & Settings
    match /siteContent/{id} { allow read: if true; allow write: if isAdmin() || isStaff(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }

    // Reports
    match /reports/{id} { allow read, write: if isSafa() || isAdmin(); }
    match /monthlyReports/{id} { allow read, write: if isSafa() || isAdmin(); }
    match /clubPointEntries/{id} { allow read: if true; allow write: if isSafa() || isAdmin(); }

    // CCE Marks
    match /cceMarks/{markId} {
      allow read: if isAcademic() || isAdmin() || (isAuthenticated() && resource.data.studentId == getUserData().admissionNumber);
      allow write: if isAcademic() || isAdmin();
    }

    // Class Dues
    match /classDues/{id} {
      allow read: if isAuthenticated();
      allow write: if isSafa() || isAdmin();
    }

    // Resumes
    match /resumes/{resumeId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
